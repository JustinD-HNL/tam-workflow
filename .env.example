# TAM Workflow — Environment Variables
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://tamworkflow:tamworkflow@localhost:5432/tamworkflow

# Encryption key for token storage (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Claude API
ANTHROPIC_API_KEY=

# Google OAuth (Calendar, Docs, Drive)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Slack — Internal Workspace (Buildkite)
SLACK_INTERNAL_CLIENT_ID=
SLACK_INTERNAL_CLIENT_SECRET=
SLACK_INTERNAL_APP_TOKEN=  # xapp-... for Socket Mode

# Slack — External Workspace (Customer-facing)
SLACK_EXTERNAL_CLIENT_ID=
SLACK_EXTERNAL_CLIENT_SECRET=
SLACK_EXTERNAL_APP_TOKEN=  # xapp-... for Socket Mode

# Linear
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# Notion
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# OAuth redirect base URL (default: http://localhost:8000)
# Set to ngrok URL if needed for HTTPS callbacks
OAUTH_REDIRECT_BASE_URL=http://localhost:8000

# App settings
LOG_LEVEL=INFO
DEBUG=false
